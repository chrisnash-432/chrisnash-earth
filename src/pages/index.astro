---
import Base from '../layouts/Base.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import Contour from '../components/Contour.astro';
import { SITE } from '../config';
import { getCollection } from 'astro:content';

const letters = (await getCollection('letters', ({ data }) => !data.draft))
  .sort((a, b) => b.data.number - a.data.number)
  .slice(0, 3);
---
<Base path="/">
  <section class="hero">
    <div class="wrap">
      <p class="kicker">{SITE.roleAnchor}</p>
      <h1>
        Seeding a regenerative culture,<br />
        through restoration of <em>inner and outer landscapes</em>.
      </h1>
      <p class="lede">
        I help organisations and communities restore degraded landscapes across Africa,
        bridging ecological science, inner development and systems thinking. Every two
        weeks I write a letter weaving the three threads of that work.
      </p>
      <NewsletterForm id="subscribe-hero" />

      <div class="metrics">
        <div class="metric"><div class="v">30,000</div><div class="k">trees a year across Southern Africa</div></div>
        <div class="metric"><div class="v">4</div><div class="k">countries with live restoration work</div></div>
        <div class="metric"><div class="v">450+</div><div class="k">community greening days</div></div>
        <div class="metric"><div class="v">10</div><div class="k">urban green zones seeded</div></div>
      </div>
      <p class="metrics-note">Through the programmes I help run with Greenpop and its partners.</p>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      <div class="sec-head">
        <span class="label">The letters</span>
        <h2>One letter, <em>three landscapes</em>.</h2>
        <p class="lede">Each issue of {SITE.newsletterName} moves through the same weave, and closes with one thing worth your time.</p>
      </div>
      <div class="grid3">
        <div class="card reveal">
          <div class="num">i.</div>
          <h3>Inner landscapes</h3>
          <p>The human dimension of restoration: nature connection, leadership, and the inner work the outer work asks of us.</p>
        </div>
        <div class="card reveal">
          <div class="num">ii.</div>
          <h3>Outer landscapes</h3>
          <p>Field intelligence from live projects: forests, urban green zones, agroforestry and bioregional strategy across Africa.</p>
        </div>
        <div class="card dusk reveal">
          <div class="num">iii.</div>
          <h3>Regenerative culture</h3>
          <p>The provocation: what systems we want to grow, and what the shift asks of organisations, economies and us.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      <div class="sec-head">
        <span class="label">Latest letters</span>
      </div>
      <div class="ledger">
        {letters.map((l) => (
          <a class="ledger-row" href={`/letters/${l.id}/`}>
            <span class="no">No. {String(l.data.number).padStart(3, '0')}</span>
            <span>
              <h3>{l.data.title}</h3>
              <p>{l.data.summary}</p>
            </span>
            <span class="date">{l.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </a>
        ))}
        <div class="ledger-row teaser">
          <span class="no">No. {String((letters[0]?.data.number ?? 0) + 1).padStart(3, '0')}</span>
          <span><h3>Arrives early August 2026</h3></span>
          <span class="date">fortnightly</span>
        </div>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      <div class="sec-head">
        <span class="label">Where the work lives</span>
        <h2>Four landscapes, one method taking shape.</h2>
      </div>
      <div class="grid3">
        <div class="reveal">
          <Contour variant="nairobi" coord="1.29°S 36.82°E · Nairobi, Kenya" height={170} />
          <h3 style="margin-top:14px">Syntropic Agroforestry for Climate Adaptation</h3>
          <p style="font-size:14.5px;color:var(--ink-soft)">A flagship demonstration site and training centre, built with a coalition to be replicated across Africa.</p>
        </div>
        <div class="reveal">
          <Contour variant="mulanje" coord="15.95°S 35.63°E · Mulanje, Malawi" height={170} />
          <h3 style="margin-top:14px">Mulanje Bioregional Strategy</h3>
          <p style="font-size:14.5px;color:var(--ink-soft)">Growing the restoration economy and regenerative value chains in a UNESCO cultural landscape.</p>
        </div>
        <div class="reveal">
          <Contour variant="uilenkraal" coord="34.66°S 19.42°E · Overberg, South Africa" height={170} />
          <h3 style="margin-top:14px">Uilenkraal Forest Restoration</h3>
          <p style="font-size:14.5px;color:var(--ink-soft)">Resilience strategies around Africa's southernmost forest, with thousands of trees planted each season.</p>
        </div>
      </div>
      <p style="margin-top:22px;font-size:14px;color:var(--ink-soft)">
        Also this year: a seven-dimension bioregional baseline for Matamp City, Sierra Leone.
        More in <a href="/now/">what I'm doing now</a>.
      </p>
    </div>
  </section>

  <div class="wrap">
    <div class="duskband reveal">
      <div class="q">"There is no better common ground than the ground beneath our feet."</div>
      <div class="a">Chris Nash</div>
    </div>
  </div>
</Base>
