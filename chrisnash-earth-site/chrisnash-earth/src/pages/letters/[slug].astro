---
import Base from '../../layouts/Base.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { SITE } from '../../config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const letters = await getCollection('letters', ({ data }) => !data.draft);
  return letters.map((l) => ({ params: { slug: l.id }, props: { letter: l } }));
}
const { letter } = Astro.props;
const { Content } = await render(letter);
const d = letter.data;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  datePublished: d.date.toISOString(),
  author: { '@type': 'Person', name: 'Chris Nash', url: SITE.url },
  publisher: { '@type': 'Person', name: 'Chris Nash' },
  description: d.summary,
  mainEntityOfPage: new URL(`/letters/${letter.id}/`, SITE.url).href
};
---
<Base title={d.title} description={d.summary} path={`/letters/${letter.id}/`} ogType="article" schema={articleSchema}>
  <article class="article">
    <div class="wrap">
      <p class="kicker">{SITE.newsletterName} · Letter No. {String(d.number).padStart(3, '0')}</p>
      <h1 style="max-width:24ch">{d.title}</h1>
      <p class="meta">
        {d.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })} · Chris Nash · read in about 5 minutes
      </p>
      <div class="prose">
        <Content />
      </div>

      {d.recommendation && (
        <aside class="rec">
          <span class="label">This letter's recommendation · {d.recommendation.kind}</span>
          <div class="t">
            {d.recommendation.url ? <a href={d.recommendation.url}>{d.recommendation.title}</a> : d.recommendation.title}
          </div>
          {d.recommendation.note && <p>{d.recommendation.note}</p>}
        </aside>
      )}

      <div style="margin-top:56px;padding-top:36px;border-top:1px solid var(--line)">
        <h2 style="font-size:24px">Get the next letter</h2>
        <NewsletterForm id="subscribe" compact={true} />
      </div>
    </div>
  </article>
</Base>
