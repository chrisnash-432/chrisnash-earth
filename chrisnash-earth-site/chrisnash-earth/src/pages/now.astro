---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('now')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const rendered = await Promise.all(
  entries.map(async (e) => ({ e, Content: (await render(e)).Content }))
);
const updated = entries[0]?.data.date;
---
<Base
  title="Now"
  description="What Chris Nash is working on right now: live restoration projects, the fortnightly letters, and where the work is this season."
  path="/now/"
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Now</p>
      <h1 style="max-width:20ch">What the work is, <em>this season</em>.</h1>
      <p class="lede">
        A living page, updated as the season moves.
        {updated && <> Last updated {updated.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}.</>}
      </p>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      {rendered.map(({ e, Content }) => (
        <div class="now-entry">
          <div class="when">
            {e.data.date.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
            {e.data.place && <span class="place">{e.data.place}</span>}
          </div>
          <div class="body">
            <h3 style="margin-bottom:8px">{e.data.title}</h3>
            <Content />
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
