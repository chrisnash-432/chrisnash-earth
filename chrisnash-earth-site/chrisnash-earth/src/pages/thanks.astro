---
import Base from '../layouts/Base.astro';
---
<Base title="Welcome" description="You're on the list for Inner & Outer Landscapes." path="/thanks/">
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Welcome, traveller</p>
      <h1 style="max-width:20ch">You're in. The next letter <em>finds you</em>.</h1>
      <p class="lede">
        One letter every two weeks: the inner landscape, the outer landscape, and the
        culture they're growing. While you wait, the first letter is a good place to
        stand.
      </p>
      <p style="margin-top:30px">
        <a class="btn" href="/letters/001-starting-with-nothing/">Read Letter No. 001</a>
      </p>
    </div>
  </section>
</Base>
