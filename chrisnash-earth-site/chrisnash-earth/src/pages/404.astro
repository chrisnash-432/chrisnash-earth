---
import Base from '../layouts/Base.astro';
---
<Base title="Not found" description="This path isn't on the map." path="/404">
  <section class="hero">
    <div class="wrap">
      <p class="kicker">404 · Off the map</p>
      <h1 style="max-width:20ch">This trail hasn't been <em>planted yet</em>.</h1>
      <p class="lede">The page you're after doesn't exist, or has moved. The letters are the best way back in.</p>
      <p style="margin-top:30px">
        <a class="btn" href="/">Back to the start</a>
        <a class="btn ghost" href="/letters/" style="margin-left:10px">Read the letters</a>
      </p>
    </div>
  </section>
</Base>
